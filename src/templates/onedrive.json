{
  "id": "onedrive",
  "version": "1.0",
  "display_name": "OneDrive",
  "icon": "📘",
  "description": "Backup auf Microsoft OneDrive via rclone",
  "category": "cloud",
  "storage_type": "rclone",
  "handler": "src.templates.handlers.onedrive_handler.OneDriveHandler",
  "platforms": ["windows", "linux", "darwin"],
  "availability_check": {
    "type": "command",
    "command": "rclone"
  },
  "ui_fields": [
    {
      "id": "remote_name",
      "type": "text",
      "label": "rclone Remote-Name",
      "required": true,
      "default": "onedrive",
      "placeholder": "onedrive"
    },
    {
      "id": "path",
      "type": "text",
      "label": "Zielordner",
      "required": false,
      "default": "Scrat-Backup",
      "placeholder": "z.B. Backups"
    },
    {
      "id": "oauth",
      "type": "button",
      "label": "Mit OneDrive verbinden",
      "action": "oauth_login"
    },
    {
      "id": "status",
      "type": "status",
      "label": ""
    }
  ],
  "config_mapping": {
    "remote_name": "remote",
    "path": "path"
  }
}
